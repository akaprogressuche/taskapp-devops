# Copy this to hosts.yml and fill in the real IPs from terraform output
# hosts.yml is git-ignored — it contains real IP addresses

all:
  vars:
    ansible_user: ubuntu
    ansible_ssh_private_key_file: ~/.ssh/id_rsa
    ansible_ssh_common_args: "-o StrictHostKeyChecking=no"

  children:
    control_plane:
      hosts:
        k3s-master:
          ansible_host: CONTROL_PLANE_IP_HERE

    workers:
      hosts:
        k3s-worker-1:
          ansible_host: WORKER_1_IP_HERE
        k3s-worker-2:
          ansible_host: WORKER_2_IP_HERE
